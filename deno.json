{
  "name": "@retr0h/swamp-nats-agent",
  "version": "0.1.0",
  "license": "MIT",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-env --allow-run --allow-net --allow-sys main.ts",
    "test": "deno test --parallel --allow-read --allow-write --allow-env --allow-run --allow-net --allow-sys",
    "check": "deno check main.ts src/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "compile": "deno run -A scripts/compile.ts",
    "vendor-protocol": "deno run --allow-read --allow-write scripts/vendor_protocol.ts",
    "check-protocol-sync": "deno run --allow-read scripts/check_protocol_sync.ts",
    "ready": "deno task fmt && deno task lint && deno task check && deno task check-protocol-sync && deno task test",
    "ready:ci": "deno task fmt:check && deno task lint && deno task check && deno task check-protocol-sync && deno task test"
  },
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@1",
    "@logtape/logtape": "jsr:@logtape/logtape@^2.0.2",
    "@logtape/pretty": "jsr:@logtape/pretty@^2.0.2",
    "@nats-io/transport-deno": "jsr:@nats-io/transport-deno@^3.0.0",
    "@nats-io/jetstream": "jsr:@nats-io/jetstream@^3.0.0",
    "@nats-io/obj": "jsr:@nats-io/obj@^3.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.18",
    "@std/encoding/base64": "jsr:@std/encoding@^1.0.7/base64",
    "@std/path": "jsr:@std/path@^1.1.4",
    "zod": "npm:zod@^4.3.6"
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
